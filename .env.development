# DAS compose 映射 mfm-api 到 8001；本地 uv run 时与 MFM_API_PORT 对齐
VITE_API_PROXY_TARGET = http://127.0.0.1:8001

# 开发环境展示「虚拟登录」（POST /admin/auth/dev-login）
VITE_DEV_MOCK_LOGIN = true

