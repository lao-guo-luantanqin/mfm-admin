# 平台本地运行端口号
VITE_PORT = 8848

VITE_PUBLIC_PATH = /

VITE_ROUTER_HISTORY = "hash"

# mfm-api 根地址（勿尾随 /）。开发留空 → 走 Vite 代理 /admin → VITE_API_PROXY_TARGET
