# 复制为 .env.development.local 覆盖联调地址

# 开发留空走 Vite 代理；直连后端时填完整 URL（勿尾随 /）
VITE_SERVER_BASEURL=
VITE_API_PROXY_TARGET=http://127.0.0.1:8001
# 七牛 Kodo 公开访问域名（自定义域名 cdn.cangyuansuanli.cn；HTTPS 证书就绪后改为 https；勿尾随 /）
VITE_CDN_BASE_URL=http://cdn.cangyuansuanli.cn
VITE_DEV_MOCK_LOGIN=true

# 腾讯地图 Web Key（管理台 GeoPoint 选点/搜索，与小程序内置腾讯地图同系）
# https://lbs.qq.com/dev/console/application/mine
VITE_TENCENT_MAP_KEY=5GYBZ-JVT3L-4TNPY-E2NXU-R4S4V-CRB6G
